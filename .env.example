# ───────────────────────────────────────────────────────────────────────────
# Simple Webinar Bot — environment configuration
#
# PRODUCTION (Render): set these in the service's "Environment" tab. Do NOT
# commit a real .env (it is gitignored).
#
# LOCAL DEVELOPMENT ONLY — override these few values on your laptop:
#   NODE_ENV=development
#   TELEGRAM_WEBHOOK_ENABLED=false
#   PUBLIC_URL=https://your-ngrok-url.ngrok-free.dev   # your ngrok HTTPS tunnel
#   ZOOM_ENABLED=false                                  # unless testing Zoom
# ───────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Render injects PORT automatically; the app reads process.env.PORT.
# This value is only used locally / when Render does not provide one.
PORT=10000

# Public HTTPS URL of the deployed service. The Telegram webhook is ALWAYS
# generated as ${PUBLIC_URL}/webhook/telegram — never hardcoded.
PUBLIC_URL=https://simple-webinar-bot.onrender.com

# In production the bot sets the Telegram webhook on startup. Keep true on Render.
TELEGRAM_WEBHOOK_ENABLED=true
TELEGRAM_DROP_PENDING_UPDATES=false

# Funnel timing: false = real schedule (days/hours). true = everything in seconds
# (quick end-to-end testing only).
SCHEDULE_TEST_MODE=false

# --- Secrets (set as real values in Render → Environment) ---
BOT_TOKEN=123456:telegram_bot_token
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GOOGLE_SHEETS_TIMEOUT_MS=30000

# Telegram IDs allowed to run /send_offer (comma-separated). Empty = disabled.
ADMIN_TELEGRAM_IDS=

# --- PostgreSQL ---
# On Render: PREFER DATABASE_URL (Render PostgreSQL → "Internal Database URL").
# If DATABASE_URL is set it takes precedence over the split vars below.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_ENABLED=true
# Used only when DATABASE_URL is NOT set (e.g. local Docker):
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=simple
DATABASE_PASSWORD=simple
DATABASE_NAME=simple_bot
DATABASE_CONNECTION_TIMEOUT_MS=1000

# --- Redis ---
# On Render: PREFER REDIS_URL (Render Key Value / Redis → "Internal URL").
# If REDIS_URL is set it takes precedence over the split vars below.
# REDIS_URL=redis://default:password@host:6379
# Used only when REDIS_URL is NOT set (e.g. local Docker):
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# --- Webinar content fallback (primary source is src/content/ru.json) ---
WEBINAR_TITLE=Как сдать экзамен ПМЖ с первого раза
WEBINAR_DATE=2026-07-01
WEBINAR_TIME=19:00
WEBINAR_TIMEZONE=Europe/Prague
ZOOM_LINK=https://zoom.us/example
PDF_GIFT_URL=https://example.com/top-20.pdf
AUDIO_URL=https://example.com/audio.mp3
WEBINAR_MATERIALS_URL=https://example.com/materials
WEBINAR_RECORDING_URL=https://example.com/recording
GROUP_LINK=https://example.com/group
DIAGNOSTIC_LINK=https://example.com/diagnostic
TRIAL_LESSON_LINK=https://example.com/trial
MANAGER_USERNAME=@manager

# --- Zoom Server-to-Server OAuth ---
# On Render set ZOOM_ENABLED=true and fill the four secrets below.
# Create a "Server-to-Server OAuth" app at https://marketplace.zoom.us
# Scopes: meeting:write:admin (or webinar:write:admin) + report:read:admin.
ZOOM_ENABLED=false
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# meeting | webinar  (ZOOM_TYPE is accepted as an alias for ZOOM_MEETING_TYPE)
ZOOM_MEETING_TYPE=meeting
ZOOM_MEETING_ID=
# Minimum minutes attended to count as "attended" (else attended_short).
ZOOM_ATTENDANCE_MINUTES=1
# Per-request timeout for Zoom API calls (ms).
ZOOM_TIMEOUT_MS=15000
