# Zoom Server-to-Server OAuth integration (optional).
# Create a "Server-to-Server OAuth" app at https://marketplace.zoom.us
# Required scopes: meeting:write:admin (or webinar:write:admin) and
# report:read:admin for the attendance report.
ZOOM_ENABLED=false
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# meeting | webinar
ZOOM_MEETING_TYPE=meeting
ZOOM_MEETING_ID=
# Minimum minutes attended to count as "attended" (else attended_short).
ZOOM_ATTENDANCE_MINUTES=1
# Per-request timeout for Zoom API calls (ms).
ZOOM_TIMEOUT_MS=15000
